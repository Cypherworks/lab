{# Managed by the monitoring role. Auth required — no anonymous access. The user
   DB persists on the ntfydata volume; the alertmanager + human users and their
   topic ACLs are provisioned by the role's tasks (ntfy user add / ntfy access). #}
base-url: "{{ monitoring_ntfy_base_url }}"
{% if monitoring_ntfy_upstream_base_url %}
# Relays a wake-up push through ntfy.sh (APNS/FCM) so the phone app gets instant
# notifications from this self-hosted server. Only a poll trigger goes upstream —
# message content stays here.
upstream-base-url: "{{ monitoring_ntfy_upstream_base_url }}"
{% endif %}
listen-http: ":80"
# Custom message templates (lab.yml) render Alertmanager webhooks; see the
# monitoring role's ntfy-alert.yml template.
template-dir: "/etc/ntfy/templates"
behind-proxy: true
cache-file: "/var/cache/ntfy/cache.db"
auth-file: "/var/lib/ntfy/user.db"
auth-default-access: "deny-all"
