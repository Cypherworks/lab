    {
      "id": 10,
      "type": "table",
      "title": "Hosts",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 8,
        "y": 7
      },
      "targets": [
        {
          "refId": "up",
          "expr": "up{job=\"node\"}",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "cpu",
          "expr": "100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])))",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "ram",
          "expr": "100 * (1 - avg by (instance) (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "disk",
          "expr": "100 * (1 - max by (instance) (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{mountpoint=\"/\"}))",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "temp",
          "expr": "(max by (instance) (node_hwmon_temp_celsius)) or (max by (instance) (node_thermal_zone_temp))",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "net",
          "expr": "sum by (instance) (rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*\"}[5m]) + rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*\"}[5m]))",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "load",
          "expr": "max by (instance) (node_load1)",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "uptime",
          "expr": "time() - max by (instance) (node_boot_time_seconds)",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "job": true,
              "__name__": true
            },
            "renameByName": {
              "instance": "Host",
              "Value #up": "Status",
              "Value #cpu": "CPU %",
              "Value #ram": "RAM %",
              "Value #disk": "Disk %",
              "Value #temp": "Temp",
              "Value #net": "Net B/s",
              "Value #load": "Load",
              "Value #uptime": "Uptime"
            },
            "indexByName": {
              "instance": 0,
              "Value #up": 1,
              "Value #cpu": 2,
              "Value #ram": 3,
              "Value #disk": 4,
              "Value #temp": 5,
              "Value #net": 6,
              "Value #load": 7,
              "Value #uptime": 8
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center",
            "minWidth": 100
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "DOWN",
                        "color": "red"
                      },
                      "1": {
                        "text": "UP",
                        "color": "green"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(CPU|RAM|Disk) %"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 75
                    },
                    {
                      "color": "red",
                      "value": 90
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Temp"
            },
            "properties": [
              {
                "id": "unit",
                "value": "celsius"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 70
                    },
                    {
                      "color": "red",
                      "value": 80
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Net B/s"
            },
            "properties": [
              {
                "id": "unit",
                "value": "Bps"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Uptime"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Load"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 4
                    },
                    {
                      "color": "red",
                      "value": 8
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "sortBy": [
          {
            "displayName": "Host"
          }
        ]
      }
    }
  ]
