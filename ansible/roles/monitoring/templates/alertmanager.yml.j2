{# Managed by the monitoring role. Alerts POST to ntfy with the role's custom
   "lab" template (see ntfy-alert.yml) for a glanceable one-line title + summary.
   Needs ntfy >= v2.14 for server-side templates. #}
route:
  receiver: ntfy
  group_by: [alertname, instance]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: {{ monitoring_alertmanager_repeat_interval }}

receivers:
  - name: ntfy
    webhook_configs:
      # priority raises it to a sound/vibrate push; tags add an icon. Both are ntfy
      # publish params applied alongside the alertmanager template.
      - url: "http://ntfy/{{ monitoring_ntfy_topic }}?template=lab&priority={{ monitoring_ntfy_alert_priority }}&tags={{ monitoring_ntfy_alert_tags }}"
        send_resolved: true
        http_config:
          basic_auth:
            username: alertmanager
            password: "{{ monitoring_ntfy_alertmanager_password }}"
