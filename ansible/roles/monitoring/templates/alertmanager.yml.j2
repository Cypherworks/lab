{# Managed by the monitoring role. Alerts POST straight to ntfy's built-in
   "alertmanager" template (firing/resolved formatting) — no bridge container.
   See https://docs.ntfy.sh/publish/ (?template=alertmanager). #}
route:
  receiver: ntfy
  group_by: [alertname, instance]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: {{ monitoring_alertmanager_repeat_interval }}

receivers:
  - name: ntfy
    webhook_configs:
      # priority raises it to a sound/vibrate push; tags add an icon. Both are ntfy
      # publish params applied alongside the alertmanager template.
      - url: "http://ntfy/{{ monitoring_ntfy_topic }}?template=alertmanager&priority={{ monitoring_ntfy_alert_priority }}&tags={{ monitoring_ntfy_alert_tags }}"
        send_resolved: true
        http_config:
          basic_auth:
            username: alertmanager
            password: "{{ monitoring_ntfy_alertmanager_password }}"
