{# Managed by the monitoring role. Hand-written snmp_exporter config for the Synology
   NAS — only the OIDs we need, so no generator/MIB toolchain in the deploy path.
   OIDs verified against the Synology MIB Guide / LibreNMS MIB mirror:
     SYNOLOGY-SYSTEM-MIB  base 1.3.6.1.4.1.6574.1
     SYNOLOGY-DISK-MIB    diskEntry 1.3.6.1.4.1.6574.2.1.1
     SYNOLOGY-RAID-MIB    raidEntry 1.3.6.1.4.1.6574.3.1.1
   Secrets (auth/priv passwords) are interpolated from ./.env at render time. #}
auths:
  synology_v3:
    version: 3
    username: "{{ monitoring_snmp_v3_username }}"
    security_level: authPriv
    password: "${SNMP_V3_AUTH_PASSWORD}"
    auth_protocol: {{ monitoring_snmp_v3_auth_protocol }}
    priv_protocol: {{ monitoring_snmp_v3_priv_protocol }}
    priv_password: "${SNMP_V3_PRIV_PASSWORD}"

modules:
  synology:
    walk:
      - 1.3.6.1.4.1.6574.1     # SYNOLOGY-SYSTEM-MIB (system status, temperature)
      - 1.3.6.1.4.1.6574.2.1.1 # SYNOLOGY-DISK-MIB diskEntry (disk temp/status)
      - 1.3.6.1.4.1.6574.3.1.1 # SYNOLOGY-RAID-MIB raidEntry (volume free/total)
    metrics:
      # --- System health + temperature ---
      - name: synology_system_status
        oid: 1.3.6.1.4.1.6574.1.1
        type: gauge
        help: SYNOLOGY-SYSTEM-MIB systemStatus - 1 Normal, 2 Failed
      - name: synology_temperature
        oid: 1.3.6.1.4.1.6574.1.2
        type: gauge
        help: SYNOLOGY-SYSTEM-MIB temperature - system temperature in Celsius
      - name: synology_power_status
        oid: 1.3.6.1.4.1.6574.1.3
        type: gauge
        help: SYNOLOGY-SYSTEM-MIB powerStatus - 1 Normal, 2 Failed
      - name: synology_system_fan_status
        oid: 1.3.6.1.4.1.6574.1.4.1
        type: gauge
        help: SYNOLOGY-SYSTEM-MIB systemFanStatus - 1 Normal, 2 Failed
      - name: synology_cpu_fan_status
        oid: 1.3.6.1.4.1.6574.1.4.2
        type: gauge
        help: SYNOLOGY-SYSTEM-MIB cpuFanStatus - 1 Normal, 2 Failed

      # --- Per-disk temperature + health (indexed by diskIndex; labelled by diskID) ---
      - name: synology_disk_id
        oid: 1.3.6.1.4.1.6574.2.1.1.2
        type: DisplayString
        help: SYNOLOGY-DISK-MIB diskID
        indexes:
          - labelname: diskIndex
            type: gauge
        lookups:
          - labels: [diskIndex]
            labelname: diskID
            oid: 1.3.6.1.4.1.6574.2.1.1.2
            type: DisplayString
      - name: synology_disk_status
        oid: 1.3.6.1.4.1.6574.2.1.1.5
        type: gauge
        help: SYNOLOGY-DISK-MIB diskStatus - 1 Normal, 2 Initialized, 3 NotInitialized, 4 SystemPartitionFailed, 5 Crashed
        indexes:
          - labelname: diskIndex
            type: gauge
        lookups:
          - labels: [diskIndex]
            labelname: diskID
            oid: 1.3.6.1.4.1.6574.2.1.1.2
            type: DisplayString
      - name: synology_disk_temperature
        oid: 1.3.6.1.4.1.6574.2.1.1.6
        type: gauge
        help: SYNOLOGY-DISK-MIB diskTemperature - disk temperature in Celsius
        indexes:
          - labelname: diskIndex
            type: gauge
        lookups:
          - labels: [diskIndex]
            labelname: diskID
            oid: 1.3.6.1.4.1.6574.2.1.1.2
            type: DisplayString

      # --- RAID / volume sizing (indexed by raidIndex; labelled by raidName) ---
      - name: synology_raid_name
        oid: 1.3.6.1.4.1.6574.3.1.1.2
        type: DisplayString
        help: SYNOLOGY-RAID-MIB raidName
        indexes:
          - labelname: raidIndex
            type: gauge
        lookups:
          - labels: [raidIndex]
            labelname: raidName
            oid: 1.3.6.1.4.1.6574.3.1.1.2
            type: DisplayString
      - name: synology_raid_status
        oid: 1.3.6.1.4.1.6574.3.1.1.3
        type: gauge
        help: SYNOLOGY-RAID-MIB raidStatus - 1 Normal, 11 Degrade, 12 Crashed
        indexes:
          - labelname: raidIndex
            type: gauge
        lookups:
          - labels: [raidIndex]
            labelname: raidName
            oid: 1.3.6.1.4.1.6574.3.1.1.2
            type: DisplayString
      - name: synology_raid_free_size
        oid: 1.3.6.1.4.1.6574.3.1.1.4
        type: gauge
        help: SYNOLOGY-RAID-MIB raidFreeSize - free bytes on the volume
        indexes:
          - labelname: raidIndex
            type: gauge
        lookups:
          - labels: [raidIndex]
            labelname: raidName
            oid: 1.3.6.1.4.1.6574.3.1.1.2
            type: DisplayString
      - name: synology_raid_total_size
        oid: 1.3.6.1.4.1.6574.3.1.1.5
        type: gauge
        help: SYNOLOGY-RAID-MIB raidTotalSize - total bytes on the volume
        indexes:
          - labelname: raidIndex
            type: gauge
        lookups:
          - labels: [raidIndex]
            labelname: raidName
            oid: 1.3.6.1.4.1.6574.3.1.1.2
            type: DisplayString
