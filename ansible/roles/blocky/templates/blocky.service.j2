{# Managed by Ansible (blocky role). #}
[Unit]
Description=blocky DNS proxy
After=network-online.target unbound.service
Wants=network-online.target

[Service]
User={{ blocky_user }}
AmbientCapabilities=CAP_NET_BIND_SERVICE
ExecStart={{ blocky_install_dir }}/blocky --config {{ blocky_install_dir }}/config.yml
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths={{ blocky_install_dir }}

[Install]
WantedBy=multi-user.target
