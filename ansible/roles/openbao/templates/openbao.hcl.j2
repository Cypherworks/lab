{# Managed by the openbao role. Single-node integrated raft; awskms auto-unseal;
   TLS listener on the package's self-signed bootstrap cert (swap for a PKI-issued
   cert once the CA exists). AWS creds come from the EnvironmentFile, not here. #}
ui            = {{ openbao_ui | string | lower }}
disable_mlock = {{ openbao_disable_mlock | string | lower }}

storage "raft" {
  path    = "{{ openbao_data_dir }}"
  node_id = "{{ openbao_node_id }}"
}

listener "tcp" {
  address       = "{{ openbao_listen_address }}"
  tls_cert_file = "{{ openbao_tls_cert_file }}"
  tls_key_file  = "{{ openbao_tls_key_file }}"
}

api_addr     = "{{ openbao_api_addr }}"
cluster_addr = "{{ openbao_cluster_addr }}"

seal "awskms" {
  region     = "{{ openbao_aws_region }}"
  kms_key_id = "{{ openbao_kms_key_id }}"
}
{% if openbao_audit_enabled %}

{# Declarative audit device — OpenBao 2.5 enables this at boot; the API enable path is
   blocked. It's the only audit device, so if this log can't be written OpenBao stops
   serving. The log dir is created before OpenBao starts (see the role's main.yml). #}
audit "file" "{{ openbao_audit_path }}" {
  options {
    file_path = "{{ openbao_audit_log_file }}"
  }
}
{% endif %}
