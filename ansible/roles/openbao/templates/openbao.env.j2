{# Managed by the openbao role. AWS credentials for the awskms auto-unseal seal,
   injected as environment by systemd (EnvironmentFile) — never written into
   openbao.hcl. Rendered 0600 root:root; systemd reads it as root at start. #}
AWS_ACCESS_KEY_ID={{ openbao_aws_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ openbao_aws_secret_access_key }}
AWS_REGION={{ openbao_aws_region }}
