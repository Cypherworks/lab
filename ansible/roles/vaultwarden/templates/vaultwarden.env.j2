{# Managed by the vaultwarden role. Passed to the container via compose env_file,
   so values are read literally — the argon2 ADMIN_TOKEN's $ characters are NOT
   subject to compose ${...} interpolation (which would corrupt them). #}
DOMAIN={{ vaultwarden_domain }}
SIGNUPS_ALLOWED={{ vaultwarden_signups_allowed | string | lower }}
{% if vaultwarden_admin_token | length > 0 %}
ADMIN_TOKEN={{ vaultwarden_admin_token }}
{% endif %}
