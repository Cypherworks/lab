{# Managed by the vaultwarden role. Docker Compose DOES interpolate env_file values,
   so a literal $ must be written as $$ (compose collapses it back to a single $ in
   the container). The argon2 ADMIN_TOKEN is full of $ delimiters, so double them;
   DOMAIN/SIGNUPS carry no $ and are left as-is. #}
DOMAIN={{ vaultwarden_domain }}
SIGNUPS_ALLOWED={{ vaultwarden_signups_allowed | string | lower }}
{% if vaultwarden_admin_token | length > 0 %}
ADMIN_TOKEN={{ vaultwarden_admin_token | replace('$', '$$') }}
{% endif %}
