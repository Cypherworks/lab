{# Managed by the vaultwarden role. Single Vaultwarden container, SQLite in /data.
   Config + the admin token come from ./vaultwarden.env (compose interpolates that
   file, so the argon2 token's $ chars are doubled there — see the env template). #}
services:
  vaultwarden:
    image: {{ vaultwarden_image }}
    restart: unless-stopped
    env_file: ./vaultwarden.env
    volumes:
      - vaultwardendata:/data
    ports:
      - "{{ vaultwarden_http_port }}:80"

volumes:
  vaultwardendata:
