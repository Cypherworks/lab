{# Managed by the caddy role. One wildcard site; routes by Host header. #}
{
	email {{ caddy_acme_email }}
{% if caddy_l4_proxies %}
	{# Raw TCP (layer4) passthrough — no TLS termination, so mutual-TLS and the
	   client's server-cert pin survive end to end. Health-checked LB fails a dead
	   backend out. Used to front the Incus API across the cluster members. #}
	layer4 {
{% for p in caddy_l4_proxies %}
		:{{ p.port }} {
			route {
				proxy {{ p.upstreams | join(' ') }} {
					lb_policy {{ p.lb_policy | default('round_robin') }}
					health_interval {{ p.health_interval | default('5s') }}
				}
			}
		}
{% endfor %}
	}
{% endif %}
}

*.{{ caddy_domain }} {
	log {
		output stdout
	}
	tls {
		dns route53
	}
{% for route in caddy_routes %}
	@{{ route.name }} host {{ route.host }}
	handle @{{ route.name }} {
		reverse_proxy {{ route.upstreams | default([route.upstream]) | join(' ') }} {
{% if (route.upstreams | default([]) | length > 1) or route.lb_policy is defined %}
			lb_policy {{ route.lb_policy | default('round_robin') }}
{% endif %}
{% if route.health_uri is defined %}
			health_uri {{ route.health_uri }}
			health_interval {{ route.health_interval | default('10s') }}
{% endif %}
{% if route.tls_skip_verify | default(false) %}
			transport http {
				tls_insecure_skip_verify
			}
{% endif %}
{% for header, value in (route.header_up | default({})).items() %}
			header_up {{ header }} "{{ value }}"
{% endfor %}
{% for header in (route.header_up_remove | default([])) %}
			header_up -{{ header }}
{% endfor %}
		}
	}
{% endfor %}
	handle {
		respond "lab ingress" 200
	}
}
