{# Managed by Ansible (keepalived role). #}
vrrp_script chk_dns {
    script "{{ keepalived_check_command }}"
    interval 5
    fall 2
    rise 2
    weight {{ keepalived_check_weight }}
}

vrrp_instance VI_DNS {
    state {{ keepalived_state }}
    interface {{ keepalived_interface }}
    virtual_router_id {{ keepalived_vrid }}
    priority {{ keepalived_priority }}
    advert_int 1
    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }
    virtual_ipaddress {
        {{ keepalived_vip }}
    }
    track_script {
        chk_dns
    }
}
