# Managed by the keepalived role. VRRP floating VIP for an active/passive pair.
{% if keepalived_check_command %}
vrrp_script {{ keepalived_check_name }} {
    script "{{ keepalived_check_command }}"
    interval {{ keepalived_check_interval }}
    fall {{ keepalived_check_fall }}
    rise {{ keepalived_check_rise }}
    weight {{ keepalived_check_weight }}
}
{% endif %}

vrrp_instance {{ keepalived_instance }} {
    state {{ keepalived_state }}
    interface {{ keepalived_interface }}
    virtual_router_id {{ keepalived_vrid }}
    priority {{ keepalived_priority }}
    advert_int 1
    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }
    virtual_ipaddress {
        {{ keepalived_vip }}
    }
{% if keepalived_check_command %}
    track_script {
        {{ keepalived_check_name }}
    }
{% endif %}
}
