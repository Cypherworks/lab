# Managed by the vector role. journald (and any extra file sources) → VictoriaLogs via its
# Elasticsearch bulk endpoint.
sources:
  journald:
    type: journald
    current_boot_only: false
{% for f in vector_file_sources %}
  {{ f.id }}:
    type: file
    include:
      - "{{ f.path }}"
{% endfor %}

sinks:
  victorialogs:
    type: elasticsearch
    inputs:
      - journald
{% for f in vector_file_sources %}
      - {{ f.id }}
{% endfor %}
    endpoints:
      - "http://{{ vector_victorialogs_endpoint }}/insert/elasticsearch/"
    api_version: v8
    compression: gzip
    healthcheck:
      enabled: false
    query:
      _msg_field: message
      _time_field: timestamp
      _stream_fields: "{{ vector_stream_fields }}"
